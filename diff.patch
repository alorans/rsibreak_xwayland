+    let
+      system = "x86_64-linux";
+      pkgs = nixpkgs.legacyPackages.${system};
+    in
+    {
+      devShells.${system}.default = pkgs.mkShell {
+        # build-time dependencies
+        nativeBuildInputs = with pkgs; [
+          cmake
+          pkg-config
+          clang-tools
+          # This wrapper hooks CMake into the Nix Qt environment
+          qt6.wrapQtAppsHook 
+          kdePackages.extra-cmake-modules
+          # kdePackages.qttools # for lupdate/lrelease etc. if used by ki18n_install
+          wayland-protocols
+          wayland
+        ];
+
+        buildInputs = with pkgs.kdePackages; [
+          wayland
+          qtbase
+          kcoreaddons
+          kconfig
+          kcrash
+          kdbusaddons
+          kdoctools
+          # kformat
+          ki18n
+          kidletime
+          knotifications
+          knotifyconfig
+          ktextwidgets
+          kxmlgui
+          kwindowsystem
+          kstatusnotifieritem
+          kcolorscheme
+        ];
+
+        shellHook = ''
+          export CMAKE_EXPORT_COMPILE_COMMANDS=ON
+        '';
+      };
+    };
+}
